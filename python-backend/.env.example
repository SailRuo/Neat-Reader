# Python Backend Configuration

# Server
HOST=127.0.0.1
PORT=3002

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Qwen API (从前端传递，这里仅作示例)
# QWEN_ACCESS_TOKEN=your_access_token_here
# QWEN_RESOURCE_URL=portal.qwen.ai

# PageIndex 配置
PAGEINDEX_CACHE_DIR=./cache/pageindex
PAGEINDEX_MAX_TREE_DEPTH=4
PAGEINDEX_MAX_PAGES_PER_NODE=10

# 日志
LOG_LEVEL=INFO
